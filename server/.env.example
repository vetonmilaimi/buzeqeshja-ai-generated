# Copy this file to .env and fill values
PORT=4000

# SMTP settings (example: Mailtrap, Gmail SMTP, SendGrid SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# From and To email addresses
FROM_EMAIL=clinic@example.com
TO_EMAIL=appointments@clinic.example.com
